--- !u!114 &1671979955
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1671979953}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e2d76ba67659a654480b134fa12256d9, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  _npcName: ShopKeeper
  _rootNode:
    npcText: Welcome to my shop. I sell seeds, tools, and animal feed. What can I
      help you with today?
    choices:
    - choiceText: What seeds do you have?
      nextNode:
        rid: 2480974677413986531
    - choiceText: I need animal feed.
      nextNode:
        rid: 2480974677413986532
    - choiceText: Just looking around.
      nextNode:
        rid: 2480974677413986533
  _npcData:
    npcName: ShopKeeper
    friendshipPoints: 0
    lowFriendshipDialogue:
      npcText: Welcome to my shop. I sell seeds, tools, and animal feed. What can
        I help you with today?
      choices:
      - choiceText: What seeds do you have?
        nextNode:
          rid: 2480974677413986534
      - choiceText: I need animal feed.
        nextNode:
          rid: 2480974677413986535
      - choiceText: Just looking around.
        nextNode:
          rid: 2480974677413986536
    midFriendshipDialogue:
      npcText: Hey there, friend! Good to see a regular face. Business has been picking
        up lately. Need anything?
      choices:
      - choiceText: Got any new stock?
        nextNode:
          rid: 2480974677413986537
      - choiceText: How is business going?
        nextNode:
          rid: 2480974677413986538
      - choiceText: Tell me about the village.
        nextNode:
          rid: 2480974677413986539
    highFriendshipDialogue:
      npcText: My favourite customer! Come in, come in! I saved something special
        just for you!
      choices:
      - choiceText: What did you save for me?
        nextNode:
          rid: 2480974677413986540
      - choiceText: Any discounts today?
        nextNode:
          rid: 2480974677413986541
      - choiceText: You're the best, ShopKeeper!
        nextNode:
          rid: 2480974677413986542
  _dialoguePanel: {fileID: 1201589485}
  _npcNameText: {fileID: 1024433372}
  _npcText: {fileID: 1416573988}
  _choiceButtonPrefab: {fileID: 8246148749650536893, guid: 574e67bcc3a729f48909719976ff9022, type: 3}
  _choicesContainer: {fileID: 1182278621}
  _interactRange: 2
  references:
    version: 2
    RefIds:
    - rid: 2480974677413986531
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: I have turnip seeds, potato seeds, and some rare melon seeds that
          just came in from the city market.
        choices: []
    - rid: 2480974677413986532
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: We carry chicken feed, cow feed, and premium sheep mix. Your animals
          will love them!
        choices: []
    - rid: 2480974677413986533
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Take your time! Everything is on the shelves. Let me know if you
          have questions.
        choices: []
    - rid: 2480974677413986534
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: I have turnip seeds, potato seeds, and some rare melon seeds that
          just came in from the city market.
        choices: []
    - rid: 2480974677413986535
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: We carry chicken feed, cow feed, and premium sheep mix. Your animals
          will love them!
        choices: []
    - rid: 2480974677413986536
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Take your time! Everything is on the shelves. Let me know if you
          have questions.
        choices: []
    - rid: 2480974677413986537
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Just got rare strawberry seeds and a golden watering can! They're
          limited stock though.
        choices: []
    - rid: 2480974677413986538
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Better than ever! The harvest festival brought lots of visitors.
          I even sold out of pumpkins.
        choices: []
    - rid: 2480974677413986539
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: This village has been here for generations. The old farm to the
          east is where it all started.
        choices: []
    - rid: 2480974677413986540
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: A legendary ancient seed! Plant it and something magical will grow.
          It's yours, no charge!
        choices: []
    - rid: 2480974677413986541
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: For you? Always! Take 20 percent off everything today. You've earned
          it, partner!
        choices: []
    - rid: 2480974677413986542
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Aw, you're making me blush! You're the reason I keep this shop running.
          Here, have a free gift!
        choices: []
