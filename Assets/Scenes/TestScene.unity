--- !u!114 &1139296136
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1139296133}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e2d76ba67659a654480b134fa12256d9, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  _npcName: Farmer
  _rootNode:
    npcText: Mornin'. The fields need tending, and the animals are hungry. Another
      long day ahead.
    choices:
    - choiceText: Need any help with the farm?
      nextNode:
        rid: 2480974677413986543
    - choiceText: Nice crops you've got.
      nextNode:
        rid: 2480974677413986544
    - choiceText: What animals do you raise?
      nextNode:
        rid: 2480974677413986545
  _npcData:
    npcName: Farmer
    friendshipPoints: 0
    lowFriendshipDialogue:
      npcText: Mornin'. The fields need tending, and the animals are hungry. Another
        long day ahead.
      choices:
      - choiceText: Need any help with the farm?
        nextNode:
          rid: 2480974677413986546
      - choiceText: Nice crops you've got.
        nextNode:
          rid: 2480974677413986547
      - choiceText: What animals do you raise?
        nextNode:
          rid: 2480974677413986548
    midFriendshipDialogue:
      npcText: Hey! The crops are growing great this season. Must be all that rain
        we got last week.
      choices:
      - choiceText: What are you growing this season?
        nextNode:
          rid: 2480974677413986549
      - choiceText: Any farming tips for beginners?
        nextNode:
          rid: 2480974677413986550
      - choiceText: How long have you been farming?
        nextNode:
          rid: 2480974677413986551
    highFriendshipDialogue:
      npcText: Partner! I was just thinking about you! Want to see the biggest pumpkin
        I've ever grown?
      choices:
      - choiceText: Show me that pumpkin!
        nextNode:
          rid: 2480974677413986552
      - choiceText: You're the best farmer in the valley!
        nextNode:
          rid: 2480974677413986553
      - choiceText: Can I have some of your harvest?
        nextNode:
          rid: 2480974677413986554
  _dialoguePanel: {fileID: 1201589485}
  _npcNameText: {fileID: 1024433372}
  _npcText: {fileID: 1416573988}
  _choiceButtonPrefab: {fileID: 8246148749650536893, guid: 574e67bcc3a729f48909719976ff9022, type: 3}
  _choicesContainer: {fileID: 1182278621}
  _interactRange: 2
  references:
    version: 2
    RefIds:
    - rid: 2480974677413986543
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Could always use a hand. The weeds are taking over the south field.
          If you pull some, I'll pay you!
        choices: []
    - rid: 2480974677413986544
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Thanks! These tomatoes took three seasons to perfect. The soil here
          is something special.
        choices: []
    - rid: 2480974677413986545
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Got chickens for eggs, cows for milk, and sheep for wool. Each one
          needs daily feeding and love.
        choices: []
    - rid: 2480974677413986546
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Could always use a hand. The weeds are taking over the south field.
          If you pull some, I'll pay you!
        choices: []
    - rid: 2480974677413986547
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Thanks! These tomatoes took three seasons to perfect. The soil here
          is something special.
        choices: []
    - rid: 2480974677413986548
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Got chickens for eggs, cows for milk, and sheep for wool. Each one
          needs daily feeding and love.
        choices: []
    - rid: 2480974677413986549
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Tomatoes, corn, wheat, and I'm trying pumpkins for the first time.
          Fingers crossed they grow big!
        choices: []
    - rid: 2480974677413986550
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: 'Three rules: water early morning, rotate your crops each season,
          and always talk to your animals. They grow happier!'
        choices: []
    - rid: 2480974677413986551
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Going on twenty years now. Started when I was just a kid, learning
          from my grandmother. Best life there is.
        choices: []
    - rid: 2480974677413986552
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Look at this beauty! It's almost as tall as me! I'm entering it
          in the festival competition for sure.
        choices: []
    - rid: 2480974677413986553
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Ha! I don't know about the best, but I sure do love what I do. Come,
          let me show you the new barn!
        choices: []
    - rid: 2480974677413986554
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Of course! Take some tomatoes and corn home. Good neighbours share
          the harvest!
        choices: []
