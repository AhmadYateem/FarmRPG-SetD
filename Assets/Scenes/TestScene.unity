--- !u!114 &1756313472
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1756313469}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e2d76ba67659a654480b134fa12256d9, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  _npcName: Villager
  _rootNode:
    npcText: Oh, hello there. Are you new around here? I don't think we've met before.
      Welcome to the village!
    choices:
    - choiceText: Yes, I just moved in.
      nextNode:
        rid: 2480974677413986555
    - choiceText: What is this place like?
      nextNode:
        rid: 2480974677413986556
    - choiceText: Where's the best spot to visit?
      nextNode:
        rid: 2480974677413986557
  _npcData:
    npcName: Villager
    friendshipPoints: 0
    lowFriendshipDialogue:
      npcText: Oh, hello there. Are you new around here? I don't think we've met
        before. Welcome to the village!
      choices:
      - choiceText: Yes, I just moved in.
        nextNode:
          rid: 2480974677413986558
      - choiceText: What is this place like?
        nextNode:
          rid: 2480974677413986559
      - choiceText: Where's the best spot to visit?
        nextNode:
          rid: 2480974677413986560
    midFriendshipDialogue:
      npcText: Hey there, neighbour! Beautiful day, isn't it? I was just picking
        some wildflowers by the road.
      choices:
      - choiceText: It sure is beautiful!
        nextNode:
          rid: 2480974677413986561
      - choiceText: What's happening in town lately?
        nextNode:
          rid: 2480974677413986562
      - choiceText: Those flowers look nice!
        nextNode:
          rid: 2480974677413986563
    highFriendshipDialogue:
      npcText: There you are! I was hoping you'd come by! I have the most exciting
        news!
      choices:
      - choiceText: What's the exciting news?
        nextNode:
          rid: 2480974677413986564
      - choiceText: I missed you too!
        nextNode:
          rid: 2480974677413986565
      - choiceText: Want to go hang out at the park?
        nextNode:
          rid: 2480974677413986566
  _dialoguePanel: {fileID: 1201589485}
  _npcNameText: {fileID: 1024433372}
  _npcText: {fileID: 1416573988}
  _choiceButtonPrefab: {fileID: 8246148749650536893, guid: 574e67bcc3a729f48909719976ff9022, type: 3}
  _choicesContainer: {fileID: 1182278621}
  _interactRange: 2
  references:
    version: 2
    RefIds:
    - rid: 2480974677413986555
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Welcome! It's a quiet little village but everyone is friendly. You'll
          love it here, I promise!
        choices: []
    - rid: 2480974677413986556
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: It's a peaceful farming community. We have a shop, a park, and beautiful
          sunsets by the river.
        choices: []
    - rid: 2480974677413986557
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: "The park is lovely in the evening. And don't miss the view from
          the hilltop \u2014 you can see the whole valley!"
        choices: []
    - rid: 2480974677413986558
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Welcome! It's a quiet little village but everyone is friendly. You'll
          love it here, I promise!
        choices: []
    - rid: 2480974677413986559
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: It's a peaceful farming community. We have a shop, a park, and beautiful
          sunsets by the river.
        choices: []
    - rid: 2480974677413986560
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: "The park is lovely in the evening. And don't miss the view from
          the hilltop \u2014 you can see the whole valley!"
        choices: []
    - rid: 2480974677413986561
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: The sky has been so clear! Perfect weather for a picnic. We should
          have one at the park sometime!
        choices: []
    - rid: 2480974677413986562
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: The harvest festival is coming up next week! Everyone is decorating
          their houses. It's going to be amazing!
        choices: []
    - rid: 2480974677413986563
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Thank you! I'm making a bouquet for the festival decorations. I
          pick a different colour every day!
        choices: []
    - rid: 2480974677413986564
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: "The mayor is building a new community garden! And guess what \u2014
          we get to help design it! How cool is that?"
        choices: []
    - rid: 2480974677413986565
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: "You're honestly my best friend in the whole village. I baked you
          some cookies \u2014 here, take them!"
        choices: []
    - rid: 2480974677413986566
      type: {class: DialogueNode, ns: , asm: Assembly-CSharp}
      data:
        npcText: Yes! Let's go right now! I packed some snacks and found the perfect
          spot under the big oak tree!
        choices: []
